<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.0"
             xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">
    <persistence-unit name="IELTSFLOW">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <!-- Entities của Minh -->
        <class>model.User</class>
        <class>model.Lesson</class>
        <class>model.Exam</class>
        <class>model.Pathway</class>
        <class>model.WeeklyPlan</class>
        <class>model.SubscriptionOrder</class>
        <class>model.SubscriptionPackage</class>
        <class>model.SystemLog</class>
        <class>model.Transaction</class>
        <class>model.Payment</class>
        <class>model.Notification</class>
        <class>model.Ticket</class>

        <properties>
            <property name="hibernate.dialect"                 value="org.hibernate.dialect.SQLServerDialect"/>
            <property name="hibernate.show_sql"                value="true"/>
        </properties>
    </persistence-unit>
</persistence>

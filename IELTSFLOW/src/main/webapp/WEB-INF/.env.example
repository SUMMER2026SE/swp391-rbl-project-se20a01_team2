# Mail configuration
RESEND_API_KEY=your_resend_api_key_here
RESEND_SEND_DOMAIN=your_email_domain_here

# Database configuration for JPA (loaded from WEB-INF/.env)
# Optional full URL. If set, this takes precedence over DB_HOST/DB_PORT/DB_NAME.
DB_URL=
DB_HOST=localhost
DB_PORT=1433
DB_NAME=IELTSFLOW
DB_USER=sa
DB_PASSWORD=your_db_password_here
DB_ENCRYPT=True
DB_TRUST_SERVER_CERT=True
DB_EXTRA_PARAMS=sendStringParametersAsUnicode=true;characterEncoding=UTF-8
